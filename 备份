local function hideObj(obj)
    if not obj then
        return
    end

    if obj:IsA("ScreenGui") then
        pcall(function()
            obj.Enabled = false
        end)
    elseif obj:IsA("GuiObject") then
        pcall(function()
            obj.Visible = false
        end)
    end

    for _, desc in ipairs(obj:GetDescendants()) do
        if desc:IsA("ScreenGui") then
            pcall(function()
                desc.Enabled = false
            end)
        elseif desc:IsA("GuiObject") then
            pcall(function()
                desc.Visible = false
            end)
        end
    end
end

local function hideKnownMenus(robloxGui)
    if not robloxGui then return end

    for name in pairs(menuNames) do
        hideObj(robloxGui:FindFirstChild(name, true))
    end
end

local function isVisibleGui(obj)
    if not obj then
        return false
    end

    local ok, visible = pcall(function()
        if obj:IsA("GuiObject") then
            return obj.Visible and obj.AbsoluteSize.X > 0 and obj.AbsoluteSize.Y > 0
        end

        if obj:IsA("ScreenGui") and not obj.Enabled then
            return false
        end

        for _, desc in ipairs(obj:GetDescendants()) do
            if desc:IsA("GuiObject") and desc.Visible and desc.AbsoluteSize.X > 0 and desc.AbsoluteSize.Y > 0 then
                return true
            end
        end

        return false
    end)

    return ok and visible
end

local function menuTriggered(obj)
    if not obj or not menuNames[obj.Name] then
        return false
    end

    if isVisibleGui(obj) then
        hideObj(obj)
        return true
    end

    return false
end

local function triggerKnownMenus(robloxGui)
    if not robloxGui then return false end

    local triggered = false

    for name in pairs(menuNames) do
        if menuTriggered(robloxGui:FindFirstChild(name, true)) then
            triggered = true
        end
    end

    return triggered
end

