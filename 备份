local function startAutoFullscreen()
    if autoFullscreenStarted then
        return
    end

    autoFullscreenStarted = true

    task.spawn(function()
        local ugs = UserSettings():GetService("UserGameSettings")
        local RunService = game:GetService("RunService")

        local F11_VK = 122
        local PRESS_RETRY_INTERVAL = 0.01
        local KEY_HOLD_TIME = 0.01

        local function isFunc(v)
            return typeof(v) == "function"
        end

        local env = _G

        if isFunc(getgenv) then
            local ok, genv = pcall(getgenv)
            if ok and type(genv) == "table" then
                env = genv
            end
        end

        local token = {}
        env.__AUTO_FULLSCREEN_TOKEN = token

        local focusMethods = {}
        local pressMethods = {}

        local function addFocusMethod(fn)
            if isFunc(fn) then
                focusMethods[#focusMethods + 1] = fn
            end
        end

        local function addPressMethod(fn)
            if isFunc(fn) then
                pressMethods[#pressMethods + 1] = fn
            end
        end

        addFocusMethod(isrbxactive)
        addFocusMethod(isgameactive)
        addFocusMethod(iswindowactive)

        local pressFns = {}
        local releaseFns = {}

        local function addPressFn(fn)
            if isFunc(fn) then
                pressFns[#pressFns + 1] = fn
            end
        end

        local function addReleaseFn(fn)
            if isFunc(fn) then
                releaseFns[#releaseFns + 1] = fn
            end
        end

        addPressFn(keypress)
        addPressFn(key_press)
        addPressFn(KeyPress)

        addReleaseFn(keyrelease)
        addReleaseFn(key_release)
        addReleaseFn(KeyRelease)

        for _, pressFn in ipairs(pressFns) do
            for _, releaseFn in ipairs(releaseFns) do
                addPressMethod(function()
                    local ok1 = pcall(pressFn, F11_VK)
                    task.wait(KEY_HOLD_TIME)
                    local ok2 = pcall(releaseFn, F11_VK)
                    return ok1 and ok2
                end)
            end
        end

        local function addTapMethod(fn)
            if isFunc(fn) then
                addPressMethod(function()
                    return pcall(fn, F11_VK)
                end)
            end
        end

        addTapMethod(keytap)
        addTapMethod(key_click)
        addTapMethod(keyclick)
        addTapMethod(keypressrelease)
        addTapMethod(KeyTap)
        addTapMethod(KeyClick)

        local vim
        pcall(function()
            vim = game:GetService("VirtualInputManager")
        end)

        if vim then
            addPressMethod(function()
                local ok1 = pcall(function()
                    vim:SendKeyEvent(true, Enum.KeyCode.F11, false, game)
                end)

                task.wait(KEY_HOLD_TIME)

                local ok2 = pcall(function()
                    vim:SendKeyEvent(false, Enum.KeyCode.F11, false, game)
                end)

                return ok1 and ok2
            end)
        end

        local function hasRobloxFocus()
            if #focusMethods == 0 then
                return true
            end

            for _, fn in ipairs(focusMethods) do
                local ok, result = pcall(fn)
                if ok and (result == true or result == 1) then
                    return true
                end
            end

            return false
        end

        local function isFullscreen()
            local ok, result = pcall(function()
                return ugs:InFullScreen()
            end)

            return ok and result == true
        end

        local methodIndex = 1

        local function pressF11()
            if #pressMethods == 0 then
                return false
            end

            local method = pressMethods[methodIndex]

            methodIndex += 1
            if methodIndex > #pressMethods then
                methodIndex = 1
            end

            local ok, result = pcall(method)
            return ok and result == true
        end

        local function waitFast()
            if RunService:IsClient() then
                RunService.RenderStepped:Wait()
            else
                RunService.Heartbeat:Wait()
            end
        end

        local nextPressTime = 0
        local wasReady = false

        while env.__AUTO_FULLSCREEN_TOKEN == token do
            local ready = hasRobloxFocus() and not isFullscreen()
            local now = os.clock()

            if ready then
                if not wasReady or now >= nextPressTime then
                    pressF11()
                    nextPressTime = os.clock() + PRESS_RETRY_INTERVAL
                end
            else
                nextPressTime = 0
            end

            wasReady = ready
            waitFast()
        end
    end)
end

